# Quarto output
_book/
_site/
*_files/
*.html
*.pdf
*.docx

# RStudio junk (safe to ignore if not using RStudio)
.Rproj.user/
.Rhistory
.RData
*.Rproj

# macOS system files
.DS_Store

# Cache or preview directories
.cache/
.quarto/

# Log files
*.log

# Editor settings
.vscode/
.idea/

# Netlify output (if building locally before deploy)
netlify.toml

# Thumbnails or previews
*.png
*.jpg
*.jpeg
*.svg

/.quarto/

**/*.quarto_ipynb

# Netlify local state (created by quarto publish)
.netlify/

# Frozen Quarto computational results — MUST be committed so CI can render
# figures without R. This negation overrides the global *.png / *.html
# ignores above; without it the frozen figures would be dropped and every
# plot on the deployed site would break.
!_freeze/
!_freeze/**
